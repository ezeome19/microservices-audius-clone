<div class="selected-artist-card">
    <img src="{{artist.profileImageUrl}}" alt="{{artist.name}}" class="selected-artist-image"
        onerror="this.src='https://placehold.co/400?text=Artist'" />
    <div class="selected-artist-info">
        <h5>{{artist.name}}</h5>
    </div>
    <button class="btn-remove" onclick="this.parentElement.remove(); selectedCount--; updateSelectedCount();">
        ✕
    </button>
</div>